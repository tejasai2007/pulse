{
  "name": "pulse",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nitrostack-cli dev",
    "dev:backend": "npm run build && node --env-file=.env --enable-source-maps dist/backend/index.js",
    "prebuild": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "nitrostack-cli build",
    "start": "nitrostack-cli start",
    "start:backend": "node --env-file=.env --enable-source-maps dist/backend/index.js",
    "mock:events": "node --env-file=.env --enable-source-maps dist/scripts/send-mock-events.js",
    "test": "npm run build && node --test dist/contracts/contracts.test.js dist/current-session.tools.test.js dist/backend/stress-engine.test.js dist/backend/speech-metrics.test.js dist/backend/session-report.test.js dist/backend/server.test.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "@nitrostack/core": "^1.0.13",
    "better-sqlite3": "^11.8.1",
    "firecrawl-cli": "^1.19.26",
    "ws": "^8.18.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@nitrostack/cli": "^1.0.14",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "22.10.0",
    "@types/ws": "^8.18.1",
    "typescript": "5.3.3"
  }
}
