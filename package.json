{
  "name": "pulse",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nitrostack-cli dev",
    "dev:backend": "npm run build && node --enable-source-maps dist/backend/index.js",
    "build": "nitrostack-cli build",
    "start": "nitrostack-cli start",
    "start:backend": "node --enable-source-maps dist/backend/index.js",
    "mock:events": "node --enable-source-maps dist/scripts/send-mock-events.js",
    "test": "npm run build && node --test dist/contracts/contracts.test.js dist/backend/server.test.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.7.4",
    "@nitrostack/core": "1.0.13",
    "firecrawl-cli": "^1.19.26",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@nitrostack/cli": "1.0.14",
    "@types/node": "22.10.0",
    "typescript": "5.3.3"
  }
}
