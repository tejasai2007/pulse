# Safe defaults run the complete Phase 1 mock path without hardware or cloud services.
NODE_ENV=development
LOG_LEVEL=info
NITROSTACK_APP_MODE=universal
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8787
BACKEND_URL=http://127.0.0.1:8787
DATABASE_PATH=data/pulse.sqlite
VITALS_SOURCE=simulated
AUDIO_INPUT=phone
TRANSCRIPTION_MODE=fixture
DEVICE_ACTIONS=simulated
COPILOT_ENABLED=true
COPILOT_MODE=automatic
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=
STORE_RAW_AUDIO=false

# Required only when TRANSCRIPTION_MODE=cloud. Never commit the value.
# DEEPGRAM_API_KEY=
